datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  DELETED
}


enum CompetitorStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SignalType {
  NEWS
  BLOG
  PRICING
  PRODUCT
  HIRING
  SOCIAL
  TECH
  PRESS
  WEBSITE
}

enum SignalStatus {
  NEW
  READ
  ARCHIVED
}

enum SignalSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PROCESSING
  READY
  FAILED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id         String   @id @default(uuid())
  fullName   String
  email      String   @unique
  password   String
  avatar     String?
  role       UserRole @default(MEMBER)
  isVerified        Boolean   @default(false)
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  verificationToken String?
  refreshToken      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  ownedWorkspaces Workspace[]    @relation("WorkspaceOwner")
  workspaceId     String?
  workspace       Workspace?     @relation("ActiveWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)
  workspaceMembers WorkspaceMember[]
  sentInvitations WorkspaceInvitation[] @relation("InvitedByUser")
  reports         Report[]       @relation("ReportAuthor")
  notifications   Notification[]
  activityLogs    ActivityLog[]

  @@index([email])
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  industry  String?
  country   String?
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownerId     String
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     WorkspaceMember[]
  activeUsers User[]            @relation("ActiveWorkspace")
  invitations WorkspaceInvitation[]
  competitors Competitor[]
  reports     Report[]
  settings    WorkspaceSetting?
  signals     Signal[]

  @@index([slug])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role      @default(VIEWER)
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model WorkspaceInvitation {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        Role      @default(VIEWER)
  token       String    @unique
  expiresAt   DateTime
  invitedBy   String
  inviter     User      @relation("InvitedByUser", fields: [invitedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

model Competitor {
  id           String           @id @default(uuid())
  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  domain       String
  industry     String?
  companySize  String?
  headquarters String?
  description  String?
  website      String
  linkedin     String?
  twitter      String?
  logo         String?
  status       CompetitorStatus @default(ACTIVE)
  categoryId   String?
  category     CompetitorCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  contacts     CompetitorContact[]
  technologies CompetitorTechnology[]
  pricingPlans CompetitorPricing[]
  social       CompetitorSocial?
  tags         CompetitorTag[]
  signals      Signal[]
  memorySnapshots MemorySnapshot[]
  reports      Report[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([status])
  @@index([deletedAt])
}

model CompetitorTag {
  id           String       @id @default(uuid())
  name         String       @unique
  color        String
  competitors  Competitor[]
}

model CompetitorCategory {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  competitors Competitor[]
}

model CompetitorContact {
  id           String     @id @default(uuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  name         String
  designation  String?
  email        String?
  linkedin     String?

  @@index([competitorId])
}

model CompetitorTechnology {
  id           String     @id @default(uuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  technology   String
  category     String?

  @@index([competitorId])
}

model CompetitorPricing {
  id           String     @id @default(uuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  planName     String
  price        Float
  currency     String     @default("USD")
  billingType  String
  description  String?

  @@index([competitorId])
}

model CompetitorSocial {
  id           String     @id @default(uuid())
  competitorId String     @unique
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  linkedin     String?
  twitter      String?
  github       String?
  youtube      String?
  instagram    String?
}

model Signal {
  id           String           @id @default(uuid())
  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitorId String
  competitor   Competitor       @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  type         SignalType
  title        String
  summary      String?
  url          String?
  source       String?
  status       SignalStatus     @default(NEW)
  publishedAt  DateTime?
  capturedAt   DateTime         @default(now())
  severity     SignalSeverity   @default(LOW)
  metadata     Json?
  createdAt    DateTime         @default(now())
  attachments  SignalAttachment[]

  @@index([workspaceId])
  @@index([competitorId])
  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model SignalSource {
  id         String     @id @default(uuid())
  name       String
  baseUrl    String?
  type       SignalType
  isEnabled  Boolean    @default(true)
  createdAt  DateTime   @default(now())
}

model SignalAttachment {
  id        String   @id @default(uuid())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileType  String?
  createdAt DateTime @default(now())

  @@index([signalId])
}

model Report {
  id           String       @id @default(uuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitorId String?
  competitor   Competitor?  @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  generatedBy  String
  author       User         @relation("ReportAuthor", fields: [generatedBy], references: [id], onDelete: Cascade)
  title        String
  summary      String?
  pdfUrl       String?
  status       ReportStatus @default(PROCESSING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([workspaceId])
  @@index([competitorId])
  @@index([generatedBy])
  @@index([status])
  @@index([createdAt])
}

model MemorySnapshot {
  id           String     @id @default(uuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  snapshotDate DateTime   @default(now())
  threatScore  Int
  estimatedARR String?
  pricing      String?
  featureCount Int        @default(0)
  strengths    Json
  weaknesses   Json
  notes        Json
  createdAt    DateTime   @default(now())

  @@index([competitorId])
  @@index([snapshotDate])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  module    String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model WorkspaceSetting {
  id                   String    @id @default(uuid())
  workspaceId          String    @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme                String    @default("light")
  language             String    @default("en")
  timezone             String    @default("UTC")
  notificationsEnabled Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([workspaceId])
}
